# ── Required ──
GEMINI_API_KEY=your_gemini_api_key

# ── Hermes Connection ──
HERMES_API_URL=http://127.0.0.1:8642
API_SERVER_KEY=sevancio-local-dev

# ── Voice ──
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Zephyr

# ── Personalization ──
SEVANCIO_USER_NAME=there

# ── Features ──
SEVANCIO_WAKE_WORD=false
SEVANCIO_SOUNDS=true
SEVANCIO_LOAD_TEST_DATA=false

# ── Advanced ──
SEVANCIO_HERMES_SESSION=sevancio-voice
SEVANCIO_HUD_HOTKEY=Alt+Space
HERMES_BIN=
HERMES_HOME=~/.hermes
